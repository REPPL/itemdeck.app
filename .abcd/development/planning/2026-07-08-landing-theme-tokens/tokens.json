{
  "name": "Premium Retro",
  "id": "premium-retro",
  "description": "Warm neutral base with confident retro accents (sunset coral, electric teal, golden yellow). A VHS-rental-shop feeling dialled to about 30%, executed with modern restraint. WCAG 2.1 AA.",
  "version": "1.0.0",
  "author": "itemdeck.app",
  "supports": ["light", "dark", "contrast"],
  "typography": {
    "displayFace": "Space Grotesk",
    "bodyFace": "Inter",
    "fallbackStack": "system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif",
    "weights": { "body": 400, "medium": 500, "semibold": 600, "bold": 700 },
    "letterSpacingHeadings": "-0.02em"
  },
  "radius": { "sm": "12px", "md": "18px", "lg": "26px", "pill": "999px" },
  "accents": {
    "coral": { "base": "#E85C46", "onLight": "#B33A28", "onDark": "#FF9781" },
    "teal":  { "base": "#0E9C99", "onLight": "#0A7876", "onDark": "#58E0DB" },
    "gold":  { "base": "#E7A72C", "onLight": "#9A6C0E", "onDark": "#F7D084" },
    "primary": "coral"
  },
  "textures": {
    "scanlineOpacity": 0.5,
    "halftoneOpacity": 0.16,
    "crtGlow": "0 0 26px rgba(232,92,70,0.35)",
    "note": "All textures are decorative and removable; the theme holds up without them."
  },
  "motion": {
    "ease": "cubic-bezier(0.22, 0.61, 0.36, 1)",
    "respectsReducedMotion": true
  },
  "themes": {
    "light": {
      "bg": "#FBF6EC", "bg2": "#F3EADA", "surface": "#FFFFFF", "surface2": "#FBF6EC",
      "ink": "#201B14", "inkSoft": "#4A4034", "inkFaint": "#6E6252",
      "line": "#E4D8C4", "lineStrong": "#CBBBA0",
      "accentCoral": "#E85C46", "accentTeal": "#0E9C99", "accentGold": "#E7A72C",
      "cardFaces": { "coral": "#F6D8CF", "teal": "#CDECEA", "gold": "#F6E6C4" }
    },
    "dark": {
      "bg": "#16130E", "bg2": "#1F1A13", "surface": "#221D16", "surface2": "#1B1610",
      "ink": "#F3ECDE", "inkSoft": "#CDC3B2", "inkFaint": "#9A8F7C",
      "line": "#352C20", "lineStrong": "#4B3F2E",
      "accentCoral": "#FF7A63", "accentTeal": "#2FD4CF", "accentGold": "#F5C25A",
      "cardFaces": { "coral": "#5A2F28", "teal": "#1E4B49", "gold": "#4D3C1C" }
    },
    "contrast": {
      "bg": "#000000", "bg2": "#0A0A0A", "surface": "#0D0D0D", "surface2": "#000000",
      "ink": "#FFFFFF", "inkSoft": "#FFFFFF", "inkFaint": "#E8E8E8",
      "line": "#FFFFFF", "lineStrong": "#FFFFFF",
      "accentCoral": "#FF9E4F", "accentTeal": "#4FF2ED", "accentGold": "#FFD84F",
      "cardFaces": { "coral": "#222222", "teal": "#222222", "gold": "#222222" }
    }
  },
  "assets": {
    "mark": "assets/itemdeck-mark.svg",
    "lockup": "assets/itemdeck-logo-lockup.svg"
  }
}
